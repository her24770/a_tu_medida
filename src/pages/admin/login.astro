---
import Layout from '@/layouts/Layout.astro';
import { SITE } from '@/config';

// Si ya está autenticado, redirigir al panel
const secret = import.meta.env.ADMIN_SECRET ?? 'changeme';
if (Astro.cookies.get('atm_admin')?.value === secret) {
  return Astro.redirect('/admin');
}
---

<Layout title="Admin — Acceso">
<div class="login-page">
  <div class="login-card">
    <div class="login-brand">
      <span class="login-dot"></span>
      {SITE.nombre}
    </div>
    <h1 class="login-title">Panel de administración</h1>

    <form class="login-form" id="login-form" novalidate>
      <div class="login-field">
        <label for="user" class="login-label">Usuario</label>
        <input id="user" name="user" type="text" class="login-input"
          autocomplete="username" required />
      </div>
      <div class="login-field">
        <label for="pass" class="login-label">Contraseña</label>
        <input id="pass" name="pass" type="password" class="login-input"
          autocomplete="current-password" required />
      </div>

      <p class="login-error" id="login-error" hidden>Credenciales incorrectas.</p>

      <button type="submit" class="login-btn" id="login-btn">Entrar</button>
    </form>
  </div>
</div>
</Layout>

<style>
.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: var(--bg);
}

.login-card {
  width: 100%;
  max-width: 380px;
  background: var(--bg);
  border-radius: 24px;
  padding: 40px 36px 44px;
  box-shadow:
    10px 10px 28px rgba(0,0,0,.08),
    -6px -6px 20px rgba(255,255,255,.85);
}
:global([data-theme="dark"]) .login-card {
  box-shadow:
    10px 10px 28px rgba(0,0,0,.5),
    -6px -6px 20px rgba(255,255,255,.02);
}

.login-brand {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 28px;
}
.login-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--accent); flex-shrink: 0;
}

.login-title {
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -.02em;
  color: var(--ink);
  margin: 0 0 32px;
  line-height: 1.2;
}

.login-form { display: flex; flex-direction: column; gap: 20px; }

.login-field { display: flex; flex-direction: column; gap: 6px; }

.login-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ink-soft);
}

.login-input {
  padding: 12px 16px;
  border-radius: 12px;
  border: 1.5px solid var(--line);
  background: var(--bg-secondary);
  color: var(--ink);
  font-size: 15px;
  font-family: var(--font);
  outline: none;
  transition: border-color .2s;
}
.login-input:focus { border-color: var(--accent); }

.login-error {
  font-size: 13px;
  color: #c0392b;
  margin: 0;
  padding: 10px 14px;
  background: rgba(192,57,43,.08);
  border-radius: 8px;
}
.login-error[hidden] { display: none; }

.login-btn {
  margin-top: 4px;
  padding: 13px;
  border-radius: 12px;
  border: none;
  background: var(--ink);
  color: var(--bg);
  font-size: 15px;
  font-weight: 600;
  font-family: var(--font);
  cursor: pointer;
  transition: opacity .2s;
}
.login-btn:hover { opacity: .85; }
.login-btn:disabled { opacity: .5; cursor: default; }
</style>

<script>
  const form  = document.getElementById('login-form') as HTMLFormElement;
  const btn   = document.getElementById('login-btn') as HTMLButtonElement;
  const error = document.getElementById('login-error') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    error.hidden = true;
    btn.disabled = true;
    btn.textContent = 'Verificando...';

    const user = (document.getElementById('user') as HTMLInputElement).value.trim();
    const pass = (document.getElementById('pass') as HTMLInputElement).value;

    try {
      const res = await fetch('/api/admin/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user, pass }),
      });

      if (res.ok) {
        window.location.href = '/admin';
      } else {
        error.hidden = false;
        btn.disabled = false;
        btn.textContent = 'Entrar';
      }
    } catch {
      error.textContent = 'Error de conexión. Intentá de nuevo.';
      error.hidden = false;
      btn.disabled = false;
      btn.textContent = 'Entrar';
    }
  });
</script>
