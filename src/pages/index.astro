---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/home/Hero.astro';
import HeroMobile from '@/components/home/HeroMobile.astro';
import Coverflow from '@/components/Coverflow.astro';
import Servicios from '@/components/home/Servicios.astro';
import Sobre from '@/components/home/Sobre.astro';
import Contacto from '@/components/home/Contacto.astro';
import { getDestacados } from '@/lib/prendas';
import { getServicios } from '@/lib/servicios';

const destacados = getDestacados();
const servicios  = getServicios();
---

<Layout title="Inicio">
  <Hero />
  <HeroMobile />
  <div class="coleccion-header">
    <h2 class="coleccion-titulo">Colección</h2>
    <a href="/catalogo" class="coleccion-ver-mas">Ver más →</a>
  </div>
  <Coverflow prendas={destacados} autoplay dots />
  <Servicios servicios={servicios} />
  <Sobre />
  <Contacto />
</Layout>

<style>
  .coleccion-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 48px 40px 0;
    max-width: var(--maxw);
    margin: 0 auto;
    width: 100%;
  }

  .coleccion-titulo {
    font-family: var(--font);
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .coleccion-ver-mas {
    font-family: var(--font);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid var(--ink);
    border-radius: 999px;
    padding: 9px 20px;
    white-space: nowrap;
    transition: background .2s, color .2s;
  }
  .coleccion-ver-mas:hover { background: var(--ink); color: var(--bg); }

  @media (max-width: 600px) {
    .coleccion-header { padding: 36px 20px 0; }
  }
</style>
