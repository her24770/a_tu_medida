---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/home/Hero.astro';
import HeroMobile from '@/components/home/HeroMobile.astro';
import Coverflow from '@/components/Coverflow.astro';
import Contacto from '@/components/home/Contacto.astro';
import { getDestacados } from '@/lib/prendas';

const destacados = getDestacados();
---

<Layout title="Inicio">
  <Hero />
  <HeroMobile />
  <Coverflow prendas={destacados} autoplay dots />
  <Contacto />
</Layout>
