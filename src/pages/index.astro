---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/home/Hero.astro';
import HeroMobile from '@/components/home/HeroMobile.astro';
import Destacados from '@/components/home/Destacados.astro';
import Contacto from '@/components/home/Contacto.astro';
import { getDestacados } from '@/lib/prendas';

const destacados = getDestacados();
---

<Layout title="Inicio">
  <Hero />
  <HeroMobile />
  <Destacados prendas={destacados} />
  <Contacto />
</Layout>
