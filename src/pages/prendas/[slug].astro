---
import Layout from '@/layouts/Layout.astro';
import { getPrendaBySlug } from '@/lib/prendas';

const { slug } = Astro.params;
const prenda = getPrendaBySlug(slug!);
if (!prenda) return Astro.redirect('/catalogo');

const MOCK_IMGS = [
  'https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=900&q=80',
  'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=900&q=80',
  'https://images.unsplash.com/photo-1539008835657-9e8e9680c956?w=900&q=80',
];
const imagenPrincipal = [...prenda.imagenes].sort((a, b) => a.orden - b.orden)[0]?.url ?? null;
const galeria = imagenPrincipal
  ? [imagenPrincipal, ...MOCK_IMGS.slice(1)]
  : MOCK_IMGS;
---

<Layout title={prenda.nombre}>
<div class="dp">

  <!-- ── Escena: imagen absoluta en el fondo ───────────────── -->
  <div class="dp-scene">

    <!-- Imagen de fondo, nunca se corta -->
    <div class="dp-img-wrap">
      <img
        id="dp-hero-img"
        src={galeria[0]}
        alt={prenda.nombre}
        class="dp-img"
        loading="eager"
      />
      <div class="dp-m-title">
        <p class="dp-m-tipo">{prenda.tipo}</p>
        <h2 class="dp-m-nombre">{prenda.nombre}</h2>
      </div>
    </div>

    <!-- Velo: funde el bg desde la izquierda para que el texto sea legible -->
    <div class="dp-veil"></div>

    <!-- Contenido encima de todo -->
    <div class="dp-content">

      <div class="dp-d-title">
        <h1 class="dp-nombre">{prenda.nombre}</h1>
        <p class="dp-tipo">{prenda.tipo}</p>
      </div>

      <p class="dp-desc">{prenda.descripcion}</p>

      {prenda.colores.length > 0 && (
        <div class="dp-section">
          <span class="dp-label">Colores</span>
          <div class="dp-colores">
            {prenda.colores.map(c => (
              <div class="dp-color-item">
                <span class="dp-swatch" style={`background:${c.hex}`}></span>
                <span class="dp-color-name">{c.nombre}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {prenda.telas.length > 0 && (
        <div class="dp-section">
          <span class="dp-label">Composición</span>
          <div class="dp-telas">
            {prenda.telas.map(t => <span class="dp-tela">{t}</span>)}
          </div>
        </div>
      )}

      {prenda.caracteristicas.length > 0 && (
        <div class="dp-section">
          <span class="dp-label">Detalles</span>
          <ul class="dp-lista">
            {prenda.caracteristicas.map(c => <li>{c}</li>)}
          </ul>
        </div>
      )}

      <div class="dp-section dp-section--last">
        <span class="dp-label">Galería</span>
        <div class="dp-strip-wrap">
          <button class="dp-sbtn" id="dp-prev" disabled aria-label="Anterior">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="dp-strip-clip">
            <div class="dp-strip" id="dp-strip">
              {galeria.map((url, i) => (
                <button class="dp-thumb" data-idx={String(i)} aria-label={`Imagen ${i + 1}`}>
                  <img src={url} alt={`${prenda.nombre} — imagen ${i + 1}`} loading="lazy" />
                </button>
              ))}
            </div>
          </div>
          <button class="dp-sbtn" id="dp-next" aria-label="Siguiente">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>

    </div><!-- /dp-content -->
  </div><!-- /dp-scene -->
</div>

<!-- ── Modal galería ─────────────────────────────────────── -->
<div class="dp-modal" id="dp-modal" hidden role="dialog" aria-modal="true" aria-label={`Galería de ${prenda.nombre}`}>
  <button class="dp-modal-close" id="dp-modal-close" aria-label="Cerrar">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
  </button>
  <span class="dp-modal-counter" id="dp-modal-counter">1 / {galeria.length}</span>

  <div class="dp-modal-body">
    <button class="dp-modal-arrow" id="dp-modal-prev" aria-label="Anterior">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <img class="dp-modal-img" id="dp-modal-img" src={galeria[0]} alt={prenda.nombre} />
    <button class="dp-modal-arrow" id="dp-modal-next" aria-label="Siguiente">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <div class="dp-modal-foot" id="dp-modal-thumbs">
    {galeria.map((url, i) => (
      <button class={`dp-modal-thumb${i === 0 ? ' dp-modal-thumb--on' : ''}`} data-idx={String(i)} aria-label={`Ir a imagen ${i + 1}`}>
        <img src={url} alt="" loading="lazy" />
      </button>
    ))}
  </div>
</div>
</Layout>

<style>
/* ── Wrapper ────────────────────────────────────────────── */
.dp {
  padding-top: 64px;
  background: var(--bg);
}

/* ── Escena: lienzo con imagen de fondo ─────────────────── */
.dp-scene {
  position: relative;
  min-height: calc(100vh - 64px);
  overflow: hidden;
  background: var(--bg);
}

/* ── Imagen: absoluta en el fondo, nunca recortada ──────── */
.dp-img-wrap { display: contents; }
.dp-m-title  { display: none; }

.dp-img {
  position: absolute;
  right: 20%; bottom: 0;
  height: 95%;
  width: auto;
  max-width: 58%;
  object-fit: contain;
  object-position: bottom right;
  z-index: 0;
  pointer-events: none;
}

/* ── Velo: bg desvaneciéndose de izquierda a transparente ── */
.dp-veil {
  position: absolute;
  inset: 0; z-index: 1;
  pointer-events: none;
  background: linear-gradient(
    to right,
    var(--bg)   0%,
    var(--bg)   22%,
    transparent 52%
  );
}

/* ── Contenido encima ───────────────────────────────────── */
.dp-content {
  position: relative;
  z-index: 2;
  width: min(48%, 540px);
  margin-left: 20%;
  padding: clamp(28px, 4vh, 56px) clamp(16px, 2vw, 28px);
  min-height: calc(100vh - 64px);
  display: flex;
  flex-direction: column;
}

/* ── Nombre + tipo ──────────────────────────────────────── */
.dp-d-title { margin-bottom: 16px; }

.dp-nombre {
  font-size: clamp(44px, 6vw, 86px);
  font-weight: 300; letter-spacing: -.03em; line-height: .92;
  color: var(--ink); margin: 0 0 8px;
}
.dp-tipo {
  font-size: clamp(14px, 1.8vw, 20px);
  font-weight: 400; color: var(--ink-soft);
  letter-spacing: .03em; margin: 0;
}

/* ── Descripción ────────────────────────────────────────── */
.dp-desc {
  font-size: 15px; line-height: 1.7; color: var(--ink-soft);
  max-width: 400px; margin: 0 0 20px;
}

/* ── Secciones ──────────────────────────────────────────── */
.dp-section { margin-bottom: 18px; }
.dp-section--last { margin-bottom: 0; flex: 1; display: flex; flex-direction: column; justify-content: flex-end; padding-bottom: clamp(28px, 4vh, 52px); }

.dp-label {
  display: block; font-size: 10.5px; font-weight: 700;
  letter-spacing: .24em; text-transform: uppercase;
  color: var(--ink-soft); margin-bottom: 10px;
}

/* ── Colores ────────────────────────────────────────────── */
.dp-colores { display: flex; flex-wrap: wrap; gap: 12px; }
.dp-color-item { display: flex; align-items: center; gap: 8px; }
.dp-swatch {
  width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0;
  box-shadow: 0 2px 6px rgba(0,0,0,.2), inset 0 0 0 1px rgba(255,255,255,.3);
}
.dp-color-name { font-size: 14px; font-weight: 500; color: var(--ink); }

/* ── Telas ──────────────────────────────────────────────── */
.dp-telas { display: flex; flex-wrap: wrap; gap: 8px; }
.dp-tela {
  font-size: 13px; font-weight: 500; color: var(--ink);
  background: var(--bg-secondary); border-radius: 999px; padding: 5px 14px;
}

/* ── Características ────────────────────────────────────── */
.dp-lista { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.dp-lista li {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 14px; color: var(--ink-soft); line-height: 1.55;
}
.dp-lista li::before {
  content: ''; width: 5px; height: 5px; border-radius: 50%;
  background: var(--accent); flex-shrink: 0; margin-top: 6px;
}

/* ── Galería strip ──────────────────────────────────────── */
.dp-strip-wrap { display: flex; align-items: center; gap: 10px; }
.dp-strip-clip { flex: 1; overflow: hidden; }
.dp-strip {
  display: flex; gap: 10px;
  transition: transform .38s cubic-bezier(.22,.61,.36,1);
}

.dp-thumb {
  flex: 0 0 auto; width: 88px; height: 114px;
  border-radius: 10px; overflow: hidden;
  border: 2px solid transparent; padding: 0; cursor: pointer;
  background: var(--bg-secondary);
  transition: border-color .2s, opacity .2s;
}
.dp-thumb:hover { opacity: .8; }
.dp-thumb--on { border-color: var(--accent); }
.dp-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

.dp-sbtn {
  flex-shrink: 0; width: 30px; height: 30px; border-radius: 50%;
  background: var(--bg); border: 1px solid var(--line);
  display: grid; place-items: center;
  cursor: pointer; color: var(--ink); transition: background .2s;
}
.dp-sbtn:hover { background: var(--bg-secondary); }
.dp-sbtn:disabled { opacity: .3; cursor: default; }

/* ── Modal ─────────────────────────────────────────────── */
.dp-modal {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(16,15,14,.92);
  backdrop-filter: blur(8px);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.dp-modal[hidden] { display: none; }

@keyframes dp-pop {
  from { opacity: 0; transform: scale(.97); }
  to   { opacity: 1; transform: scale(1); }
}

.dp-modal-close {
  position: absolute; top: 20px; right: 20px;
  width: 40px; height: 40px; border-radius: 50%;
  background: rgba(255,255,255,.12); border: none;
  cursor: pointer; color: #fff;
  display: grid; place-items: center; transition: background .2s;
}
.dp-modal-close:hover { background: rgba(255,255,255,.22); }

.dp-modal-counter {
  position: absolute; top: 26px; left: 24px;
  font-size: 13px; font-weight: 500;
  color: rgba(255,255,255,.6); letter-spacing: .08em;
}

.dp-modal-body {
  display: flex; align-items: center; gap: 16px;
  width: 100%; padding: 0 16px; flex: 1; min-height: 0;
}

.dp-modal-arrow {
  flex-shrink: 0; width: 44px; height: 44px; border-radius: 50%;
  background: rgba(255,255,255,.12); border: none;
  cursor: pointer; color: #fff;
  display: grid; place-items: center; transition: background .2s;
}
.dp-modal-arrow:hover { background: rgba(255,255,255,.22); }

.dp-modal-img {
  max-width: min(560px, 80vw); max-height: 64vh;
  object-fit: contain; border-radius: 8px;
  box-shadow: 0 24px 70px rgba(0,0,0,.5);
  animation: dp-pop .28s ease; display: block; margin: 0 auto;
}

.dp-modal-foot {
  display: flex; gap: 10px; justify-content: center;
  margin: 20px 0 28px;
  max-width: 92vw; overflow-x: auto; padding: 0 12px;
}

.dp-modal-thumb {
  flex: 0 0 auto; width: 52px; height: 68px; border-radius: 6px;
  overflow: hidden; cursor: pointer;
  background: rgba(255,255,255,.1);
  border: 2px solid transparent; padding: 0;
  opacity: .45; transition: opacity .2s, border-color .2s;
}
.dp-modal-thumb:hover { opacity: .75; }
.dp-modal-thumb--on { opacity: 1; border-color: rgba(255,255,255,.75); }
.dp-modal-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Modal móvil ────────────────────────────────────────── */
@media (max-width: 680px) {
  .dp-modal-close { top: 12px; right: 12px; width: 36px; height: 36px; }
  .dp-modal-counter { top: 18px; left: 14px; font-size: 12px; }
  .dp-modal-body { gap: 6px; padding: 0 6px; }
  .dp-modal-arrow { width: 34px; height: 34px; background: rgba(255,255,255,.18); }
  .dp-modal-img { max-width: 92vw; max-height: 58vh; border-radius: 6px; }
  .dp-modal-foot { gap: 6px; margin: 12px 0 18px; padding: 0 8px; }
  .dp-modal-thumb { width: 40px; height: 52px; border-radius: 4px; }
}

/* ── Responsive móvil ───────────────────────────────────── */
@media (max-width: 680px) {
  .dp-scene { min-height: unset; }

  /* Wrap relativo para poder superponer el título */
  .dp-img-wrap {
    display: block;
    position: relative;
    height: 52svh;
    overflow: hidden;
    background: var(--bg);
  }

  /* Imagen ocupa todo el wrap */
  .dp-img {
    position: relative;
    right: unset; bottom: unset;
    width: 100%; height: 100%;
    max-width: 100%;
    object-fit: contain;
    object-position: bottom center;
    pointer-events: auto;
  }

  /* Título superpuesto en esquina inferior izquierda de la imagen */
  .dp-m-title {
    display: block;
    position: absolute;
    bottom: 14px; left: 16px;
    pointer-events: none;
  }
  .dp-m-tipo {
    font-size: 11px; font-weight: 700;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--ink-soft); margin: 0 0 4px;
  }
  .dp-m-nombre {
    font-size: clamp(22px, 6vw, 32px);
    font-weight: 300; letter-spacing: -.03em; line-height: .95;
    color: var(--ink); margin: 0;
  }

  /* Oculta el título del panel de contenido en móvil */
  .dp-d-title { display: none; }

  /* Sin velo en móvil */
  .dp-veil { display: none; }

  /* Contenido a ancho completo debajo de la imagen */
  .dp-content {
    position: relative;
    width: 100%;
    margin-left: 0;
    min-height: unset;
    padding: 24px clamp(20px, 5vw, 36px) 40px;
  }

  .dp-desc { max-width: none; }
  .dp-thumb { width: 76px; height: 98px; }
  .dp-section--last { flex: unset; padding-bottom: 0; justify-content: unset; }
}
</style>

<script>
  const strip   = document.getElementById('dp-strip')!;
  const prevBtn = document.getElementById('dp-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('dp-next') as HTMLButtonElement;
  const thumbs  = [...strip.querySelectorAll<HTMLButtonElement>('.dp-thumb')];
  const THUMB_W = () => (thumbs[0]?.offsetWidth ?? 88) + 10;
  const VISIBLE = 3;
  const TOTAL   = thumbs.length;
  let   stripIdx = 0;

  function updateStrip() {
    strip.style.transform = `translateX(-${stripIdx * THUMB_W()}px)`;
    prevBtn.disabled = stripIdx === 0;
    nextBtn.disabled = TOTAL <= VISIBLE || stripIdx >= TOTAL - VISIBLE;
  }

  prevBtn.addEventListener('click', () => { stripIdx = Math.max(0, stripIdx - 1); updateStrip(); });
  nextBtn.addEventListener('click', () => { stripIdx = Math.min(TOTAL - VISIBLE, stripIdx + 1); updateStrip(); });
  updateStrip();

  // Click en thumbnail → abre modal (no cambia imagen de fondo)
  thumbs.forEach((btn, i) => {
    btn.addEventListener('click', () => openModal(i));
  });

  // ── Modal ────────────────────────────────────────────────
  const modal       = document.getElementById('dp-modal')!;
  const modalImg    = document.getElementById('dp-modal-img') as HTMLImageElement;
  const modalCtr    = document.getElementById('dp-modal-counter')!;
  const modalThumbs = [...document.querySelectorAll<HTMLButtonElement>('.dp-modal-thumb')];
  const URLS        = modalThumbs.map(t => t.querySelector('img')!.src);
  let   modalIdx    = 0;

  function openModal(idx: number) {
    modalIdx = idx; syncModal();
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }
  function syncModal() {
    modalImg.style.animation = 'none';
    void modalImg.offsetWidth;
    modalImg.style.animation = '';
    modalImg.src = URLS[modalIdx];
    modalCtr.textContent = `${modalIdx + 1} / ${URLS.length}`;
    modalThumbs.forEach((t, i) => t.classList.toggle('dp-modal-thumb--on', i === modalIdx));
  }

  function prevModal() { modalIdx = (modalIdx - 1 + URLS.length) % URLS.length; syncModal(); }
  function nextModal() { modalIdx = (modalIdx + 1) % URLS.length; syncModal(); }

  document.getElementById('dp-modal-close')!.addEventListener('click', closeModal);
  document.getElementById('dp-modal-prev')!.addEventListener('click', prevModal);
  document.getElementById('dp-modal-next')!.addEventListener('click', nextModal);
  modalThumbs.forEach((t, i) => t.addEventListener('click', () => { modalIdx = i; syncModal(); }));
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  document.addEventListener('keydown', e => {
    if (modal.hasAttribute('hidden')) return;
    if (e.key === 'Escape')     closeModal();
    if (e.key === 'ArrowLeft')  prevModal();
    if (e.key === 'ArrowRight') nextModal();
  });
</script>
