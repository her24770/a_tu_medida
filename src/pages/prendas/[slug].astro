---
import Layout from '@/layouts/Layout.astro';
import GaleriaImagenes from '@/components/GaleriaImagenes.astro';
import { getPrendaBySlug } from '@/lib/prendas';

const { slug } = Astro.params;
const prenda = getPrendaBySlug(slug!);

if (!prenda) {
  return Astro.redirect('/catalogo');
}
---

<Layout title={prenda.nombre}>
  <article>
    <GaleriaImagenes imagenes={prenda.imagenes} />

    <div>
      <h1>{prenda.nombre}</h1>
      <span>{prenda.tipo}</span>
      <span>{prenda.categoria}</span>
      <p>{prenda.descripcion}</p>

      {prenda.colores.length > 0 && (
        <div>
          <h2>Colores</h2>
          <div>
            {prenda.colores.map(color => (
              <span style={`background-color: ${color.hex}`} title={color.nombre} />
            ))}
          </div>
        </div>
      )}

      {prenda.telas.length > 0 && (
        <div>
          <h2>Telas</h2>
          <ul>{prenda.telas.map(tela => <li>{tela}</li>)}</ul>
        </div>
      )}

      {prenda.caracteristicas.length > 0 && (
        <div>
          <h2>Características</h2>
          <ul>{prenda.caracteristicas.map(c => <li>{c}</li>)}</ul>
        </div>
      )}

      {prenda.tiempoEntrega && (
        <p>Tiempo de entrega: {prenda.tiempoEntrega}</p>
      )}
    </div>
  </article>
</Layout>
