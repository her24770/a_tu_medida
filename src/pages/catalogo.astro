---
import Layout from '@/layouts/Layout.astro';
import CardPrenda from '@/components/CardPrenda.astro';
import FiltroCategoria from '@/components/FiltroCategoria.astro';
import { connectDB } from '@/lib/db';
import { Prenda } from '@/models/Prenda';
import type { Prenda as TPrenda, Categoria } from '@/types/prenda';

const tipo = Astro.url.searchParams.get('tipo') ?? undefined;
const categoria = (Astro.url.searchParams.get('categoria') ?? undefined) as Categoria | undefined;

await connectDB();

const filtro: Record<string, unknown> = { disponible: true };
if (tipo) filtro.tipo = tipo;
if (categoria) filtro.categoria = categoria;

const prendas = await Prenda.find(filtro).sort({ creadoEn: -1 }).lean() as unknown as TPrenda[];
---

<Layout title="Catálogo">
  <h1>Catálogo</h1>
  <FiltroCategoria categoriaActual={categoria} tipoActual={tipo} />
  <div>
    {prendas.length === 0
      ? <p>No hay prendas disponibles.</p>
      : prendas.map(prenda => <CardPrenda prenda={prenda} />)
    }
  </div>
</Layout>
