---
import Layout from '@/layouts/Layout.astro';
import CardPrenda from '@/components/CardPrenda.astro';
import FiltroCategoria from '@/components/FiltroCategoria.astro';
import { getPrendas } from '@/lib/prendas';
import { getCategorias } from '@/lib/categorias';

const tipo       = Astro.url.searchParams.get('tipo')      ?? undefined;
const categoria  = Astro.url.searchParams.get('categoria') ?? undefined;

const prendas    = getPrendas(tipo, categoria);
const categorias = getCategorias();
---

<Layout title="Catálogo">
  <h1>Catálogo</h1>
  <FiltroCategoria {categorias} categoriaActual={categoria} tipoActual={tipo} />
  <div>
    {prendas.length === 0
      ? <p>No hay prendas disponibles.</p>
      : prendas.map(prenda => <CardPrenda prenda={prenda} />)
    }
  </div>
</Layout>
