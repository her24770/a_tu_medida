---
import type { Prenda } from '@/types/prenda';

interface Props { prenda: Prenda; }
const { prenda } = Astro.props;

const MOCK = 'https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=600&q=80';
const img  = [...prenda.imagenes].sort((a, b) => a.orden - b.orden)[0]?.url ?? MOCK;

// Formatea slug a texto legible: "vestido-de-novia" → "Vestido de novia"
function fmtSlug(s: string) {
  return s.split('-').map((w, i) => i === 0 ? w.charAt(0).toUpperCase() + w.slice(1) : w).join(' ');
}
---

<a href={`/prendas/${prenda.slug}`} class="card">
  <div class="card-img-wrap">
    <img src={img} alt={prenda.nombre} class="card-img" loading="lazy" />
  </div>
  <div class="card-body">
    <span class="card-cat">{fmtSlug(prenda.categoria)}</span>
    <h3 class="card-nombre">{prenda.nombre}</h3>
    <p class="card-tipo">{prenda.tipo}</p>
    {prenda.colores.length > 0 && (
      <div class="card-colores">
        {prenda.colores.slice(0, 4).map(c => (
          <span class="card-swatch" style={`background:${c.hex}`} title={c.nombre}></span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
.card {
  display: flex;
  flex-direction: column;
  border-radius: 18px;
  background: var(--bg);
  text-decoration: none;
  overflow: hidden;
  box-shadow:
    6px 6px 18px rgba(0,0,0,.07),
    -4px -4px 12px rgba(255,255,255,.85);
  transition: transform .25s ease, box-shadow .25s ease;
}
:global([data-theme="dark"]) .card {
  box-shadow:
    6px 6px 18px rgba(0,0,0,.45),
    -4px -4px 12px rgba(255,255,255,.03);
}
.card:hover {
  transform: translateY(-5px);
  box-shadow:
    10px 14px 28px rgba(0,0,0,.1),
    -4px -4px 12px rgba(255,255,255,.85);
}
:global([data-theme="dark"]) .card:hover {
  box-shadow:
    10px 14px 28px rgba(0,0,0,.55),
    -4px -4px 12px rgba(255,255,255,.03);
}

/* Imagen */
.card-img-wrap {
  width: 100%;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: var(--bg-secondary);
  flex-shrink: 0;
}
.card-img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .45s ease;
}
.card:hover .card-img { transform: scale(1.04); }

/* Cuerpo */
.card-body {
  padding: 18px 20px 22px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.card-cat {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 2px;
}

.card-nombre {
  font-size: 18px;
  font-weight: 700;
  letter-spacing: -.01em;
  color: var(--ink);
  margin: 0;
  line-height: 1.2;
}

.card-tipo {
  font-size: 13px;
  color: var(--ink-soft);
  margin: 0;
  line-height: 1.4;
}

/* Swatches de colores */
.card-colores {
  display: flex;
  gap: 6px;
  margin-top: 10px;
}
.card-swatch {
  width: 16px; height: 16px; border-radius: 50%;
  display: inline-block; flex-shrink: 0;
  box-shadow: 0 1px 4px rgba(0,0,0,.2), inset 0 0 0 1px rgba(255,255,255,.3);
}
</style>
