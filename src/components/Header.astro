---
---
<nav class="nav">
  <a href="/" class="brand"><span class="dot"></span>A tu medida</a>
  <div class="nav-links">
    <a href="/">Inicio</a>
    <a href="/catalogo">Galería</a>
    <a href="/#contacto">Contáctame</a>
  </div>
  <div class="nav-actions">
    <button id="theme-toggle" class="theme-toggle" aria-label="Cambiar tema">
      <span class="icon-light">☀</span>
      <span class="icon-dark">☾</span>
    </button>
  </div>
  <button class="nav-burger" id="nav-burger" aria-label="Menú">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="nav-mobile" id="nav-mobile" aria-hidden="true">
  <button class="nm-close" id="nm-close" aria-label="Cerrar menú">✕</button>
  <a href="/" class="nm-link">Inicio</a>
  <a href="/catalogo" class="nm-link">Galería</a>
  <a href="/#contacto" class="nm-link">Contáctame</a>
</div>

<style is:global>
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px;
    padding: 22px clamp(20px, 5vw, 64px);
    color: var(--ink);
    transition: color .35s ease, background .35s ease, padding .35s ease;
  }
  body:not(.loaded) .nav { opacity: 0; transform: translateY(-12px); transition: none; }
  .nav.in {
    opacity: 1; transform: none;
    transition: opacity .9s ease .15s, transform .9s ease .15s,
                color .35s ease, background .35s ease, padding .35s ease;
  }

  .brand {
    font-weight: 700; font-size: 19px; letter-spacing: -.01em;
    display: flex; align-items: center; gap: 9px; white-space: nowrap;
    color: inherit; text-decoration: none;
  }
  .brand .dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: currentColor; display: inline-block;
  }

  .nav-links {
    display: flex; align-items: center; gap: clamp(18px, 3vw, 40px);
    font-size: 15px; color: inherit;
  }
  .nav-links a { color: inherit; text-decoration: none; opacity: .9; transition: opacity .2s; }
  .nav-links a:hover { opacity: 1; }

  .nav-actions { display: flex; align-items: center; gap: 12px; }

  .theme-toggle {
    background: none; border: 1px solid var(--line); border-radius: 999px;
    padding: 6px 12px; cursor: pointer; color: var(--ink);
    font-size: 14px; transition: background .2s;
    display: flex; align-items: center; gap: 4px;
  }
  .theme-toggle:hover { background: var(--bg-secondary); }
  .icon-dark { display: none; }
  [data-theme="dark"] .icon-light { display: none; }
  [data-theme="dark"] .icon-dark  { display: inline; }

  .nav-burger {
    display: none;
    background: none; border: none; cursor: pointer;
    padding: 4px; color: var(--ink);
  }
  .nav-burger span {
    display: block; width: 24px; height: 2px;
    background: currentColor; margin: 5px 0;
    transition: transform .3s ease, opacity .3s ease;
  }
  .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.open span:nth-child(2) { opacity: 0; }
  .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .nav-mobile {
    display: none;
    position: fixed; inset: 0; z-index: 48;
    background: var(--bg);
    flex-direction: column; align-items: center; justify-content: center; gap: 36px;
  }
  .nav-mobile.open { display: flex; }
  .nm-close {
    position: absolute; top: 24px; right: clamp(20px, 5vw, 64px);
    background: none; border: none; cursor: pointer;
    font-size: 22px; color: var(--ink-soft);
  }
  .nm-link {
    font-size: clamp(32px, 10vw, 52px); font-weight: 700;
    color: var(--ink); text-decoration: none; letter-spacing: -.02em;
    transition: color .2s;
  }
  .nm-link:hover { color: var(--ink-soft); }

  body.scrolled .nav {
    background: var(--nav-scrolled-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding-top: 16px; padding-bottom: 16px;
    box-shadow: 0 1px 0 var(--line);
  }

  @media (max-width: 880px) {
    .nav-links  { display: none; }
    .nav-burger { display: flex; flex-direction: column; }
  }
</style>

<script>
  // Scroll → nav opaco
  function onScroll() {
    document.body.classList.toggle('scrolled', window.scrollY > 30);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Animación de entrada
  function reveal() {
    document.body.classList.add('loaded');
    document.querySelector('.nav')?.classList.add('in');
  }
  if (document.readyState === 'complete') requestAnimationFrame(reveal);
  else window.addEventListener('load', () => requestAnimationFrame(reveal));
  setTimeout(reveal, 1000);

  // Toggle modo oscuro
  const toggle = document.getElementById('theme-toggle');
  const html   = document.documentElement;

  toggle?.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // Menú móvil
  const burger     = document.getElementById('nav-burger');
  const mobileMenu = document.getElementById('nav-mobile');
  const nmClose    = document.getElementById('nm-close');

  function toggleMenu(open: boolean) {
    burger?.classList.toggle('open', open);
    mobileMenu?.classList.toggle('open', open);
    mobileMenu?.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  burger?.addEventListener('click', () => toggleMenu(!burger.classList.contains('open')));
  nmClose?.addEventListener('click', () => toggleMenu(false));
  mobileMenu?.querySelectorAll('.nm-link').forEach(link => {
    link.addEventListener('click', () => toggleMenu(false));
  });
</script>
