---
import { SITE, WHATSAPP_URL } from '@/config';
const WHATSAPP_DISPLAY = SITE.whatsappDisplay;
---

<section class="contacto-section" id="contacto">
  <div class="contacto-inner">

    <div class="contacto-cta">
      <span class="contacto-eyebrow">Contacto</span>
      <h2 class="contacto-title">¿Tenés una idea en mente?</h2>
      <p class="contacto-sub">
        Contame qué querés hacer y lo convertimos en realidad.<br />
        Primera consulta sin costo.
      </p>
      <div class="contacto-wa-group">
        <a href={WHATSAPP_URL} target="_blank" rel="noopener" class="contacto-wa-btn">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribime por WhatsApp
        </a>
        <span class="contacto-wa-num">{WHATSAPP_DISPLAY}</span>
      </div>
    </div>

    <div class="contacto-info">
      <div class="contacto-card">
        <div class="ci-block">
          <span class="ci-label">Ubicación</span>
          <span class="ci-value">Zona 3, Ciudad de Guatemala</span>
        </div>
        <div class="ci-divider"></div>
        <div class="ci-block">
          <span class="ci-label">Horario de atención</span>
          <span class="ci-value">Lunes a Sábado<br />7:00 am — 6:00 pm</span>
        </div>
        <div class="ci-divider"></div>
        <div class="ci-block">
          <span class="ci-label">Atención</span>
          <span class="ci-value">Solo con cita previa</span>
        </div>
        <div class="ci-divider"></div>
        <div class="ci-block">
          <span class="ci-label">Pedidos grandes</span>
          <span class="ci-value">Uniformes, bandas y pedidos en cantidad deben solicitarse con al menos 4 semanas de anticipación.</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .contacto-section {
    padding: 96px clamp(20px, 6vw, 80px);
    background: var(--bg-secondary);
  }

  .contacto-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }

  /* CTA */
  .contacto-eyebrow {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 14px;
  }

  .contacto-title {
    font-size: clamp(30px, 4vw, 52px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--ink);
    margin-bottom: 18px;
  }

  .contacto-sub {
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin-bottom: 36px;
  }

  .contacto-wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25d366;
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity .2s, transform .2s;
    box-shadow: 0 4px 20px rgba(37,211,102,.35);
  }
  .contacto-wa-btn:hover {
    opacity: .9;
    transform: translateY(-2px);
  }

  .contacto-wa-group {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .contacto-wa-num {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }

  /* Info card */
  .contacto-card {
    background: var(--bg);
    border-radius: 20px;
    padding: 36px 32px;
    box-shadow:
      8px 8px 20px rgba(0,0,0,0.06),
      -4px -4px 14px rgba(255,255,255,0.85);
  }

  :global([data-theme="dark"]) .contacto-card {
    box-shadow:
      8px 8px 20px rgba(0,0,0,0.4),
      -4px -4px 14px rgba(255,255,255,0.02);
  }

  .ci-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 0;
  }

  .ci-divider {
    height: 1px;
    background: var(--line);
  }

  .ci-label {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .ci-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.55;
  }

  .ci-block:last-child .ci-value {
    font-size: 14px;
    font-weight: 400;
    color: var(--ink-soft);
  }

  .ci-link {
    text-decoration: none;
    color: var(--ink);
    transition: color .2s;
  }
  .ci-link:hover { color: var(--ink-soft); }

  @media (max-width: 760px) {
    .contacto-section  { padding: 64px clamp(20px, 5vw, 40px); }
    .contacto-inner    { grid-template-columns: 1fr; gap: 40px; }
    .contacto-card     { padding: 28px 24px; }
  }
</style>
