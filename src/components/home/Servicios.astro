---
import type { Servicio } from '@/lib/servicios';

interface Props { servicios: Servicio[]; }
const { servicios } = Astro.props;

const ICONS: Record<string, string> = {
  school:   `<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  music:    `<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>`,
  heart:    `<path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>`,
  star:     `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
  formal:   `<path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  scissors: `<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>`,
  tool:     `<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>`,
  chat:     `<path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>`,
};
---

<section class="svc-section">
  <div class="svc-inner">
    <div class="svc-header reveal">
      <span class="svc-eyebrow">Qué hacemos</span>
      <h2 class="svc-title">Cada prenda,<br /><span class="svc-thin">una historia distinta.</span></h2>
    </div>

    <div class="svc-grid">
      {servicios.map((s, i) => (
        <div class="reveal" style={`--reveal-delay: ${i * 60}ms`}>
          <div class="svc-card">
            <span class="svc-num">{(i + 1).toString().padStart(2, '0')}</span>
            <div class="svc-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
                stroke="currentColor" stroke-width="1.8"
                stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={ICONS[s.icono] ?? ICONS.tool} />
              </svg>
            </div>
            <h3 class="svc-name">{s.nombre}</h3>
            <p class="svc-desc">{s.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .svc-section {
    padding: 96px clamp(20px, 6vw, 80px);
    background: var(--bg);
  }

  .svc-inner {
    max-width: var(--maxw);
    margin: 0 auto;
  }

  .svc-header {
    margin-bottom: 56px;
  }

  .svc-eyebrow {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 14px;
  }

  .svc-title {
    font-size: clamp(32px, 4.5vw, 56px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--ink);
  }

  .svc-thin {
    font-weight: 300;
    font-style: italic;
  }

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .svc-card {
    height: 100%;
    position: relative;
    overflow: hidden;
    background: var(--bg);
    border-radius: 20px;
    border-top: 2.5px solid var(--accent);
    padding: 32px 28px;
    box-shadow:
      8px 8px 20px rgba(0,0,0,0.07),
      -4px -4px 14px rgba(255,255,255,0.85);
    transition: transform .25s ease, box-shadow .25s ease;
  }

  .svc-card:hover {
    transform: translateY(-4px);
    box-shadow:
      12px 12px 28px rgba(0,0,0,0.09),
      -4px -4px 14px rgba(255,255,255,0.85);
  }

  :global([data-theme="dark"]) .svc-card {
    box-shadow:
      8px 8px 20px rgba(0,0,0,0.45),
      -4px -4px 14px rgba(255,255,255,0.03);
  }

  :global([data-theme="dark"]) .svc-card:hover {
    box-shadow:
      12px 12px 28px rgba(0,0,0,0.55),
      -4px -4px 14px rgba(255,255,255,0.03);
  }

  /* Número de orden decorativo */
  .svc-num {
    position: absolute;
    top: 14px;
    right: 20px;
    font-size: 72px;
    font-weight: 900;
    line-height: 1;
    color: rgba(0,0,0,.05);
    pointer-events: none;
    user-select: none;
    font-variant-numeric: tabular-nums;
  }
  :global([data-theme="dark"]) .svc-num { color: rgba(255,255,255,.06); }

  .svc-icon {
    width: 50px;
    height: 50px;
    border-radius: 14px;
    background: var(--accent);
    box-shadow: 0 6px 16px rgba(184,149,106,.35);
    display: grid;
    place-items: center;
    margin-bottom: 22px;
    color: #fff;
  }

  .svc-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }

  .svc-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  @media (max-width: 900px) {
    .svc-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .svc-section { padding: 64px clamp(20px, 5vw, 40px); }
    .svc-grid    { grid-template-columns: 1fr; gap: 16px; }
    .svc-header  { margin-bottom: 36px; }
  }
</style>
