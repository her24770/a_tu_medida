---
import type { Categoria } from '@/lib/categorias';

interface Props {
  categorias: Categoria[];
  categoriaActual?: string;
  tipoActual?: string;
}

const { categorias, categoriaActual, tipoActual } = Astro.props;

function urlFiltro(slug?: string) {
  const params = new URLSearchParams();
  if (tipoActual) params.set('tipo', tipoActual);
  if (slug) params.set('categoria', slug);
  const qs = params.toString();
  return `/catalogo${qs ? `?${qs}` : ''}`;
}
---

<nav>
  <a href={urlFiltro()}>Todas</a>
  {categorias.map(cat => (
    <a
      href={urlFiltro(cat.slug)}
      aria-current={categoriaActual === cat.slug ? 'page' : undefined}
    >
      {cat.nombre}
    </a>
  ))}
</nav>
