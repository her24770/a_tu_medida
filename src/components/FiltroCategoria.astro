---
import type { Categoria } from '@/types/prenda';

interface Props {
  categoriaActual?: Categoria;
  tipoActual?: string;
}

const { categoriaActual, tipoActual } = Astro.props;

const categorias: Categoria[] = ['noche', 'civil', 'quinceañera', 'casual', 'playa'];

function urlFiltro(categoria?: Categoria) {
  const params = new URLSearchParams();
  if (tipoActual) params.set('tipo', tipoActual);
  if (categoria) params.set('categoria', categoria);
  const qs = params.toString();
  return `/catalogo${qs ? `?${qs}` : ''}`;
}
---

<nav>
  <a href={urlFiltro()}>Todas</a>
  {categorias.map(cat => (
    <a
      href={urlFiltro(cat)}
      aria-current={categoriaActual === cat ? 'page' : undefined}
    >
      {cat}
    </a>
  ))}
</nav>
